# ===========================================
# TranscribeX Environment Variables
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/transcribex?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# OpenAI API Key (for transcription and translation)
OPENAI_API_KEY="sk-..."

# Storage configuration
# For MVP: "local" uses persistent disk storage
# Future: "s3" for object storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage"

# Optional: S3-compatible storage (for future use)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# App configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MAX_UPLOAD_SIZE_MB="500"
MAX_FILE_DURATION_MINUTES="180"

# Processing defaults
DEFAULT_PROCESSING_MODE="balanced"

# Cloud Storage Providers (all optional — pickers only show if configured)
# Google Drive: Get from https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# OneDrive: Get from https://portal.azure.com → App registrations
NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=""

# Dropbox: Get from https://www.dropbox.com/developers/apps
NEXT_PUBLIC_DROPBOX_APP_KEY=""

# Node environment
NODE_ENV="development"
