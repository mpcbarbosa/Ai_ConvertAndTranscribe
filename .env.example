# ===========================================
# TranscribeX Environment Variables
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/transcribex?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# OpenAI API Key (for transcription and translation)
OPENAI_API_KEY="sk-..."

# Storage configuration
# For MVP: "local" uses persistent disk storage
# Future: "s3" for object storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage"

# Optional: S3-compatible storage (for future use)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# App configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MAX_UPLOAD_SIZE_MB="500"
MAX_FILE_DURATION_MINUTES="180"

# Processing defaults
DEFAULT_PROCESSING_MODE="balanced"

# Node environment
NODE_ENV="development"
