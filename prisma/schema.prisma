generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  uploaded
  queued
  converting
  transcribing
  post_processing
  translating
  generating_outputs
  generating_report
  completed
  failed
  cancelled
}

enum ProcessingMode {
  best_quality
  balanced
}

enum SourceType {
  video
  audio
}

enum ArtifactType {
  original
  mp3
  transcript_txt
  transcript_json
  translation_txt
  translation_json
  srt
  vtt
  meeting_report
}

enum LogLevel {
  info
  warn
  error
  debug
}

model Job {
  id               String         @id @default(cuid())
  originalFileName String
  originalMimeType String
  originalFileSize BigInt
  sourceType       SourceType
  sourceLanguage   String?
  detectedLanguage String?
  targetLanguage   String?
  uiLanguage       String         @default("en")
  processingMode   ProcessingMode @default(balanced)
  status           JobStatus      @default(uploaded)
  providerUsed     String?
  durationSeconds  Float?
  errorMessage     String?
  meetingReport    String?        // AI-generated meeting report
  progress         Int            @default(0) // 0-100 overall progress
  currentStage     String?        // current stage description
  cancelRequested  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?

  artifacts        JobArtifact[]
  segments         TranscriptSegment[]
  logs             ProcessingLog[]
  timings          StageTiming[]

  @@index([status])
  @@index([createdAt])
}

model JobArtifact {
  id          String       @id @default(cuid())
  jobId       String
  type        ArtifactType
  storagePath String
  mimeType    String
  sizeBytes   BigInt       @default(0)
  createdAt   DateTime     @default(now())

  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model TranscriptSegment {
  id             String   @id @default(cuid())
  jobId          String
  startMs        Int
  endMs          Int
  speakerLabel   String?
  sourceText     String
  translatedText String?
  confidence     Float?
  chunkIndex     Int      @default(0)
  segmentIndex   Int      @default(0)
  createdAt      DateTime @default(now())

  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, chunkIndex, segmentIndex])
}

model ProcessingLog {
  id        String   @id @default(cuid())
  jobId     String
  stage     String
  level     LogLevel @default(info)
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, stage])
}

model StageTiming {
  id          String   @id @default(cuid())
  jobId       String
  stage       String
  startedAt   DateTime
  completedAt DateTime?
  durationMs  Int?
  createdAt   DateTime @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
